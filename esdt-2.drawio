        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" value="5" vertex="1">
          <mxGeometry height="38" width="40" x="1169" y="437" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" value="6" vertex="1">
          <mxGeometry height="38" width="40" x="1170" y="526" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" value="7" vertex="1">
          <mxGeometry height="38" width="40" x="1169.5" y="618" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-13" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span data-path-to-node=&quot;5,1&quot;&gt;&lt;b&gt;Deterministic Global Ingress:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span data-path-to-node=&quot;5,1&quot;&gt;AWS Global Accelerator ingests global player traffic at the nearest edge location, routing UDP/TCP packets over the private, congestion-free AWS backbone to drastically minimize in-game latency, jitter, and packet loss.&amp;nbsp;&lt;/span&gt;&lt;span data-path-to-node=&quot;5,2&quot;&gt;&lt;sup class=&quot;superscript&quot; data-turn-source-index=&quot;8&quot;&gt;&lt;/sup&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="77.5" width="449" x="1220.5" y="62.5" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-14" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span data-path-to-node=&quot;6,1&quot;&gt;&lt;b&gt;Game Server Orchestration:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span data-path-to-node=&quot;6,1&quot;&gt;Custom routing accelerators forward traffic deterministically to Amazon GameLift, which dynamically provisions and scales compute fleets to seamlessly handle massive fluctuations in Concurrent Connected Users (CCU) during peak tournament hours.&amp;nbsp;&lt;/span&gt;&lt;span data-path-to-node=&quot;6,2&quot;&gt;&lt;sup class=&quot;superscript&quot; data-turn-source-index=&quot;8&quot;&gt;&lt;/sup&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90.5" width="450" x="1219.5" y="163.5" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-15" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span data-path-to-node=&quot;7,1&quot;&gt;&lt;b&gt;Real-Time Telemetry Streaming:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span data-path-to-node=&quot;7,1&quot;&gt;Amazon Kinesis ingests massive volumes of real-time game events, matchmaking logs, and player behavior telemetry directly from the game servers, establishing a highly decoupled and scalable data ingestion pipeline.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="117" width="450" x="1219.5" y="255.5" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-16" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span data-path-to-node=&quot;8,1&quot;&gt;&lt;b&gt;High-Performance Persistence:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span data-path-to-node=&quot;8,1&quot;&gt;Amazon Aurora PostgreSQL securely manages the persistent game state and player economy. It is deployed in a Multi-Availability Zone topology to ensure continuous operational availability and rapid, automated failover.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="121" width="450" x="1219.5" y="348.5" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-17" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span data-path-to-node=&quot;9,1&quot;&gt;&lt;b&gt;Cost-Optimized Data Lake:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span data-path-to-node=&quot;9,1&quot;&gt;Telemetry data and historical logs are archived in Amazon S3 Intelligent-Tiering. This storage class utilizes algorithmic automation to cascade inactive game logs to colder storage tiers, effectively eliminating storage management overhead.&amp;nbsp;&lt;/span&gt;&lt;span data-path-to-node=&quot;9,2&quot;&gt;&lt;sup class=&quot;superscript&quot; data-turn-source-index=&quot;10&quot;&gt;&lt;/sup&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="114" width="449" x="1220.5" y="437.5" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-18" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span data-path-to-node=&quot;10,1&quot;&gt;&lt;b&gt;Serverless Analytics Engine:&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span data-path-to-node=&quot;10,1&quot;&gt;Amazon Athena provides a highly scalable, serverless interactive query service, allowing data engineers to execute complex ANSI SQL queries directly against the raw, unstructured telemetry data residing in the Amazon S3 data lake.&amp;nbsp;&lt;/span&gt;&lt;span data-path-to-node=&quot;10,2&quot;&gt;&lt;sup class=&quot;superscript&quot; data-turn-source-index=&quot;11&quot;&gt;&lt;/sup&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="118" width="450" x="1220.5" y="527.5" as="geometry" />
        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-19" parent="1" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;" value="&lt;span data-path-to-node=&quot;11,1&quot;&gt;&lt;b&gt;Business Intelligence Visualization:&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span data-path-to-node=&quot;11,1&quot;&gt;Amazon QuickSight consumes the processed data to render interactive, real-time dashboards, empowering product managers to derive profound insights into player engagement, tournament performance, and monetization behaviors.&amp;nbsp;&lt;/span&gt;&lt;span data-path-to-node=&quot;11,2&quot;&gt;&lt;sup class=&quot;superscript&quot; data-turn-source-index=&quot;3&quot;&gt;&lt;/sup&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="113" width="449" x="1220.5" y="618.5" as="geometry" />
        </mxCell>
