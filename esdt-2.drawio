        </mxCell>
        <mxCell id="7OVz4w7n9kzEPWy-4BBC-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=none;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;" value="4" vertex="1">
